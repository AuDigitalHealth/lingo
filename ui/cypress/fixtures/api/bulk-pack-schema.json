{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Bulk Pack Size Creation",
  "properties": {
    "newPackSizeInput": {
      "$ref": "#/$defs/PackDetails"
    },
    "addPackSizeButton": {
      "type": "null",
      "title": "Add Pack Size"
    },
    "packSizes": {
      "type": "array",
      "title": "Pack Sizes",
      "items": { "$ref": "#/$defs/PackDetails" }
    }
  },
  "$defs": {
    "PackDetails": {
      "type": "object",
      "title": "Pack Details",
      "properties": {
        "packSize": { "type": "number", "title": "Pack Size" },
        "nonDefiningProperties": {
          "type": "array",
          "title": "Non Defining Properties",
          "items": { "type": "object" }
        }
      }
    },
    "MEDICATION_PRODUCT_NonDefiningProperty": {
      "anyOf": []
    },
    "MEDICATION_PACKAGE_NonDefiningProperty": {
      "anyOf": []
    }
  }
}
